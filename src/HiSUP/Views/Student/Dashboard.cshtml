@using HiSUP.Models
@model Student

@{
    ViewData["Title"] = "Student Dashboard";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3>Welcome, @Model.Name!</h3>
                </div>
                <div class="card-body">
                    <h5>Student Information</h5>
                    <table class="table">
                        <tr><th>Student ID:</th><td>@Model.StudentID</td></tr>
                        <tr><th>Name:</th><td>@Model.Name</td></tr>
                        <tr><th>Email:</th><td>@Model.Email</td></tr>
                        <tr><th>Phone:</th><td>@Model.Phone</td></tr>
                        <tr><th>CGPA:</th><td>@Model.CGPA</td></tr>
                    </table>

                    <!-- ADD THIS BUTTON SECTION RIGHT HERE -->
                    <div class="mt-3">
                        <a href="/Student/Register" class="btn btn-success">Register Courses</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>