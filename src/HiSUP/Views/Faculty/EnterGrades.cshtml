@{
    ViewData["Title"] = "Enter Grades";
    int sectionId = ViewBag.SectionId;
    var students = Model as IEnumerable<dynamic>;
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h3>Enter Student Grades</h3>
        </div>
        <div class="card-body">
            <form method="post">
                <input type="hidden" name="sectionId" value="@sectionId" />

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Student ID</th>
                            <th>Student Name</th>
                            <th>Grade (0-100)</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in students)
                        {
                            <tr>
                                <td>@student.StudentID</td>
                                <td>@student.Name</td>
                                <td>
                                    <input type="number" name="grade" class="form-control"
                                           min="0" max="100" step="1" required />
                                </td>
                                <td>
                                    <button type="submit" name="enrollmentId" value="@student.EnrollmentID"
                                            class="btn btn-primary btn-sm">
                                        Save Grade
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <a asp-action="Dashboard" asp-route-id="500" class="btn btn-secondary">Back to Dashboard</a>
            </form>
        </div>
    </div>
</div>